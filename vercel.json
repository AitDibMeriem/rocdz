{
  "version": 2,
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "cd artifacts/api-server && node ./build.mjs",
  "outputDirectory": "artifacts/api-server",
  "functions": {
    "api/index.js": {
      "includeFiles": "dist/**",
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ]
}
