{
  "version": 2,
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "buildCommand": "node ./build.mjs",
  "outputDirectory": ".",
  "functions": {
    "api/index.js": {
      "includeFiles": "dist/**",
      "memory": 512,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ]
}
